# ─── 应用 ─────────────────────────────────────
APP_NAME=Music API
DEBUG=true
LOG_LEVEL=INFO

# ─── 数据库 ───────────────────────────────────
DATABASE_URL=sqlite:///./items.db

# ─── JWT 认证 ─────────────────────────────────
JWT_SECRET_KEY=                        # 不填则启动时随机生成
ACCESS_TOKEN_EXPIRE_MINUTES=60
